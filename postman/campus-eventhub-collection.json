{
  "info": {
    "_postman_id": "campus-eventhub-collection",
    "name": "Campus EventHub — All Services",
    "description": "Complete API collection for Campus EventHub.\n\n**Setup:**\n1. Import both `campus-eventhub-collection.json` and `campus-eventhub-environment.json`\n2. Select the `Campus EventHub — Local` environment\n3. Start the stack: `docker compose up` or `./start-all.sh`\n\n**Demo flow (run in order):**\n1. Infrastructure → Eureka Health + Gateway Health\n2. Venue Service → Create Venue\n3. Event Service → Create Event\n4. Registration Service → Register Student\n5. Ticket Service → Get Ticket (auto-generated via RabbitMQ)\n6. Attendance Service → Mark Attendance\n7. Certificate Service → Get Certificate (auto-generated via RabbitMQ)\n8. Feedback Service → Submit Feedback\n9. Leaderboard Service → Publish Result\n10. Announcement Service → Create Announcement\n\nIDs are **auto-captured** into environment variables by the test scripts on each create request — just run them top to bottom.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [

    {
      "name": "00 — Infrastructure",
      "item": [
        {
          "name": "Eureka Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{eurekaUrl}}/actuator/health", "host": ["{{eurekaUrl}}"], "path": ["actuator", "health"] },
            "description": "Verify Eureka Server is UP. Visit http://localhost:4070 to see the dashboard."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/actuator/health", "host": ["{{baseUrl}}"], "path": ["actuator", "health"] },
            "description": "Verify API Gateway is UP on port 4069."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Eureka Registered Apps",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{eurekaUrl}}/eureka/apps", "host": ["{{eurekaUrl}}"], "path": ["eureka", "apps"] },
            "description": "List all services registered in Eureka. All 13 services should appear as UP."
          }
        }
      ]
    },

    {
      "name": "01 — Venue Service",
      "item": [
        {
          "name": "Create Venue",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/venues", "host": ["{{baseUrl}}"], "path": ["api", "venues"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Main Auditorium\",\n  \"location\": \"Block A, Ground Floor\",\n  \"capacity\": 300,\n  \"type\": \"AUDITORIUM\",\n  \"facilities\": \"Projector, AC, Stage\"\n}" },
            "description": "Create a new venue. Saves venueId to environment."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Created 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.environment.set('venueId', json.id);",
            "pm.test('Has ID', () => pm.expect(json.id).to.be.a('number'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get All Venues",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/venues", "host": ["{{baseUrl}}"], "path": ["api", "venues"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Venue by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/venues/{{venueId}}", "host": ["{{baseUrl}}"], "path": ["api", "venues", "{{venueId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Check Venue Availability",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/venues/{{venueId}}/availability?startTime=2026-08-01T09:00:00&endTime=2026-08-01T17:00:00",
              "host": ["{{baseUrl}}"], "path": ["api", "venues", "{{venueId}}", "availability"],
              "query": [
                { "key": "startTime", "value": "2026-08-01T09:00:00" },
                { "key": "endTime",   "value": "2026-08-01T17:00:00" }
              ]
            }
          }
        },
        {
          "name": "Book Venue for Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/venues/{{venueId}}/book", "host": ["{{baseUrl}}"], "path": ["api", "venues", "{{venueId}}", "book"] },
            "body": { "mode": "raw", "raw": "{\n  \"eventId\": {{eventId}},\n  \"startTime\": \"2026-08-01T09:00:00\",\n  \"endTime\": \"2026-08-01T17:00:00\"\n}" },
            "description": "Book a venue for an event. Run after creating both a venue and an event."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 201) {",
            "  pm.environment.set('bookingId', pm.response.json().id);",
            "}"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Venue for Event",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/venues/event/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "venues", "event", "{{eventId}}"] }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/venues/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["api", "venues", "bookings", "{{bookingId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('No Content 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "02 — Event Service",
      "item": [
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Annual Tech Summit 2026\",\n  \"description\": \"The biggest tech event of the year.\",\n  \"eventDate\": \"2026-08-01T10:00:00\",\n  \"endDate\": \"2026-08-01T17:00:00\",\n  \"category\": \"TECHNICAL\",\n  \"maxCapacity\": 200\n}" },
            "description": "Create a new event. Saves eventId to environment."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Created 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.environment.set('eventId', json.id);",
            "pm.test('Status UPCOMING', () => pm.expect(json.status).to.eql('UPCOMING'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Events by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/events/status/UPCOMING", "host": ["{{baseUrl}}"], "path": ["api", "events", "status", "UPCOMING"] },
            "description": "Filter by status: UPCOMING, ONGOING, or COMPLETED."
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Annual Tech Summit 2026 — Updated\",\n  \"description\": \"Updated description.\",\n  \"eventDate\": \"2026-08-01T10:00:00\",\n  \"maxCapacity\": 250\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Update Capacity (increment)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}/capacity", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "capacity"] },
            "body": { "mode": "raw", "raw": "{\n  \"delta\": 1\n}" },
            "description": "Tracks how many students are currently registered (currentRegistrations). Pass delta: +1 when someone registers, -1 when they cancel. This is different from maxCapacity (the ceiling)."
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('No Content 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "03 — Registration Service",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/registrations", "host": ["{{baseUrl}}"], "path": ["api", "registrations"] },
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"studentName\": \"{{studentName}}\",\n  \"studentEmail\": \"{{studentEmail}}\",\n  \"eventId\": {{eventId}}\n}" },
            "description": "Register a student for an event. Saves registrationId to environment. Also triggers ticket + notification via RabbitMQ."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Created 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.environment.set('registrationId', json.id);",
            "pm.test('Status ACTIVE', () => pm.expect(json.status).to.eql('ACTIVE'));",
            "pm.test('Has ID', () => pm.expect(json.id).to.be.a('number'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Registration by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/registrations/{{registrationId}}", "host": ["{{baseUrl}}"], "path": ["api", "registrations", "{{registrationId}}"] }
          }
        },
        {
          "name": "Get Registrations by Event",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/registrations/event/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "registrations", "event", "{{eventId}}"] }
          }
        },
        {
          "name": "Get Registrations by Student",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/registrations/student/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["api", "registrations", "student", "{{studentId}}"] }
          }
        },
        {
          "name": "Check Registration Exists",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/registrations/{{registrationId}}/exists", "host": ["{{baseUrl}}"], "path": ["api", "registrations", "{{registrationId}}", "exists"] },
            "description": "Used internally by attendance-service to validate before marking attendance."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Exists true', () => pm.expect(pm.response.json().exists).to.be.true);"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Cancel Registration",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/registrations/{{registrationId}}", "host": ["{{baseUrl}}"], "path": ["api", "registrations", "{{registrationId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('No Content 204', () => pm.response.to.have.status(204));"
          ], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "04 — Ticket Service",
      "item": [
        {
          "name": "Get Ticket by Registration ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/registration/{{registrationId}}", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "registration", "{{registrationId}}"] },
            "description": "Ticket is auto-generated when a registration is created via RabbitMQ. Wait ~2s after registering before calling this."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.environment.set('ticketId', json.id);",
            "pm.test('Has QR code', () => pm.expect(json.qrCode).to.include('data:image/png;base64,'));",
            "pm.test('Status VALID', () => pm.expect(json.status).to.eql('VALID'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{ticketId}}"] }
          }
        },
        {
          "name": "Validate Ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}/validate", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{ticketId}}", "validate"] },
            "description": "Returns the ticket with its current status (VALID / USED / CANCELLED)."
          }
        },
        {
          "name": "Mark Ticket as Used",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/tickets/{{ticketId}}/mark-used", "host": ["{{baseUrl}}"], "path": ["api", "tickets", "{{ticketId}}", "mark-used"] },
            "description": "Call this at the event entry gate to mark the ticket as USED."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status USED', () => pm.expect(pm.response.json().status).to.eql('USED'));"
          ], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "05 — Notification Service",
      "item": [
        {
          "name": "Get Notifications by Student",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/notifications/student/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "student", "{{studentId}}"] },
            "description": "Returns all notifications logged for this student. Should contain a REGISTRATION notification after registering."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "if (json.length > 0) pm.environment.set('notificationId', json[0].id);"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Notification by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/notifications/{{notificationId}}", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "{{notificationId}}"] }
          }
        },
        {
          "name": "Get Notifications by Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/notifications/type/REGISTRATION", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "type", "REGISTRATION"] },
            "description": "Types: REGISTRATION, ANNOUNCEMENT, RESULT, REMINDER, VENUE_CHANGE."
          }
        }
      ]
    },

    {
      "name": "06 — Attendance Service",
      "item": [
        {
          "name": "Mark Attendance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/attendance", "host": ["{{baseUrl}}"], "path": ["api", "attendance"] },
            "body": { "mode": "raw", "raw": "{\n  \"registrationId\": {{registrationId}},\n  \"studentId\": \"{{studentId}}\",\n  \"studentName\": \"{{studentName}}\",\n  \"studentEmail\": \"{{studentEmail}}\",\n  \"eventId\": {{eventId}},\n  \"eventTitle\": \"Annual Tech Summit 2026\"\n}" },
            "description": "Mark a student as present. Also triggers certificate generation via RabbitMQ."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Created 201', () => pm.response.to.have.status(201));",
            "const json = pm.response.json();",
            "pm.environment.set('attendanceId', json.id);",
            "pm.test('Status PRESENT', () => pm.expect(json.status).to.eql('PRESENT'));"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Attendance by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/attendance/{{attendanceId}}", "host": ["{{baseUrl}}"], "path": ["api", "attendance", "{{attendanceId}}"] }
          }
        },
        {
          "name": "Check Attendance Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/attendance/{{registrationId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "attendance", "{{registrationId}}", "status"] },
            "description": "Returns whether this registration has been marked present and when."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Present', () => pm.expect(pm.response.json().present).to.be.true);"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Attendance by Event",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/attendance/event/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "attendance", "event", "{{eventId}}"] }
          }
        },
        {
          "name": "Get Attendance by Student",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/attendance/student/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["api", "attendance", "student", "{{studentId}}"] }
          }
        }
      ]
    },

    {
      "name": "07 — Certificate Service",
      "item": [
        {
          "name": "Get Certificate by Registration ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/certificates/registration/{{registrationId}}", "host": ["{{baseUrl}}"], "path": ["api", "certificates", "registration", "{{registrationId}}"] },
            "description": "Certificate is auto-generated when attendance is marked. Wait ~2s after marking attendance."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.environment.set('certificateId', json.id);",
            "pm.environment.set('certificateNumber', json.certificateNumber);",
            "pm.test('Has PDF', () => pm.expect(json.hasPdf).to.be.true);"
          ], "type": "text/javascript" } }]
        },
        {
          "name": "Get Certificate by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/certificates/{{certificateId}}", "host": ["{{baseUrl}}"], "path": ["api", "certificates", "{{certificateId}}"] }
          }
        },
        {
          "name": "Get Certificate by Number",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/certificates/number/{{certificateNumber}}", "host": ["{{baseUrl}}"], "path": ["api", "certificates", "number", "{{certificateNumber}}"] },
            "description": "Public verification endpoint — look up a certificate by its unique number."
          }
        },
        {
          "name": "Get Certificates by Student",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/certificates/student/{{studentId}}", "host": ["{{baseUrl}}"], "path": ["api", "certificates", "student", "{{studentId}}"] }
          }
        },
        {
          "name": "Download Certificate PDF",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/certificates/{{certificateId}}/pdf", "host": ["{{baseUrl}}"], "path": ["api", "certificates", "{{certificateId}}", "pdf"] },
            "description": "Downloads the certificate as a PDF file. Response Content-Type is application/pdf."
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Content-Type PDF', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf'));"
          ], "type": "text/javascript" } }]
        }
      ]
    },

    {
      "name": "08 — Feedback Service",
      "item": [
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/feedback", "host": ["{{baseUrl}}"], "path": ["api", "feedback"] },
            "body": { "mode": "raw", "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"studentName\": \"{{studentName}}\",\n  \"eventId\": {{eventId}},\n  \"rating\": 5,\n  \"comment\": \"Excellent event! Very well organized.\"\n}" },
